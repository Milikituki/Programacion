<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
            minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tiendaapp.MainController">
   <top>
      <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Primera app JavaFX" BorderPane.alignment="CENTER">
         <font>
            <Font name="Comic Sans MS Bold" size="16.0" />
         </font>
      </Text>
   </top>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <center>
      <VBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <TextField fx:id="editNombre" alignment="CENTER" promptText="Introduce tu nombre" />
            <Button fx:id="buttonSaludar" mnemonicParsing="false" text="Saludar">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
            </Button>
         </children>
      </VBox>
   </center>
   <bottom>
      <Text fx:id="editText" strokeType="OUTSIDE" strokeWidth="0.0" BorderPane.alignment="CENTER" />
   </bottom>
</BorderPane>
